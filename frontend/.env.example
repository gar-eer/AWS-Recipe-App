# Leave unset to use same-origin /api (recommended for EC2 + Nginx).
# VITE_API_URL=https://your-domain.example/api
# Optional local proxy target; defaults to http://127.0.0.1:5000
VITE_DEV_API_TARGET=http://127.0.0.1:5000
VITE_AWS_REGION=ap-south-1
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
